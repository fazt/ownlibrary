[
  {
    "id": "TC001",
    "title": "Registro exitoso crea sesión y muestra el dashboard",
    "description": "Verifica que un usuario pueda registrarse y que, tras el registro, se cree sesión y se muestre el dashboard en la ruta raíz.",
    "category": "Autenticación de usuarios",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Click on the control that switches to \"Registro\" / \"Registrarse\" mode"
      },
      {
        "type": "action",
        "description": "Type \"Usuario Prueba\" into the name field"
      },
      {
        "type": "action",
        "description": "Type \"usuario.prueba+reg1@example.com\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"Password123!\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Registrarse\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/\""
      },
      {
        "type": "assertion",
        "description": "Verify element \"Dashboard\" is visible"
      }
    ]
  },
